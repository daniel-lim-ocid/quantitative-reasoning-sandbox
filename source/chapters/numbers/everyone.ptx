  <!-- Exercises are placed in a dedicated division at the end of the section -->
  <exercises xml:id="exercises-numbers-everyone">
    <exercise>
      <statement>
        <p>
          Do you know what the quadratic formula is and what it can be used for?
        </p>
      </statement>
      <hint>
        <p>
          It's that long equation you learn in Algebra 1
        </p>
      </hint>
      <answer>
        <p>
          <m>x = \frac{-b \pm \sqrt{b^2 - 4ac}}{2a}</m>
        </p>
      </answer>
    </exercise>
    <exercise>
      <statement>
        <p>
          Do you know what the quadratic formula is and what it can be used for?
        </p>
